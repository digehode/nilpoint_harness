{% partialdef game_list %}
    <ul>
        {% for game in nilpoint.games %}
            <li><a hx-get="{{ game.get_dispatch_url }}?action=landing"
   hx-target="#nilpoint-container"
   href="#">{{ game.instance_name }} ({{ game.name }})</a></li>
        {% endfor %}
    </ul>
{% endpartialdef %}
{% partialdef game_info %}
    {% if game %}
        <h1 class="nilpoint nilpoint-h1 nilpoint-game-info-title">{{ game.instance_name }}</h1>
        <p>{{ game.instance_description }}</p>
        <p>This is an instance of the {{ game.name }} gametype.  {{ game.description }}</p>
    {% else %}
        <p>To use this partial, you need to ensure a game object is refered-to by the template varable 'game'.</p>
        <p>Example:</p>
        <pre>{% verbatim %}
  {% with game=nilpoint.games.0 %}
    {% include "nilpoint/game_info.jinja2#game_info" %}
  {% endwith %}
{% endverbatim %}</pre>
    {% endif %}
{% endpartialdef %}
